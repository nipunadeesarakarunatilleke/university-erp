        <mxCell id="19" value="&lt;b&gt;Middleware&lt;/b&gt;&lt;br&gt;auth.js (JWT verify)&lt;br&gt;&lt;br&gt;&lt;b&gt;Routes&lt;/b&gt;&lt;br&gt;transcripts.js&lt;br&gt;&lt;br&gt;&lt;b&gt;Key Endpoints&lt;/b&gt;&lt;br&gt;GET /transcripts/:id&lt;br&gt;GET /transcripts/:id/full&lt;br&gt;&lt;br&gt;&lt;b&gt;Models&lt;/b&gt;&lt;br&gt;(aggregation — no own data)&lt;br&gt;&lt;br&gt;&lt;b&gt;Sync REST&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#1a56db&quot;&gt;→ Student Svc (profile)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#1a56db&quot;&gt;→ Result Svc (grades)&lt;/font&gt;"
