          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#a855f7;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=6;"
          vertex="1" parent="1">
          <mxGeometry x="834" y="218" width="255" height="258" as="geometry" />
        </mxCell>

        <!-- TRANSCRIPT SERVICE -->
        <mxCell id="18" value="Transcript Service · :3005"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#14b8a6;strokeColor=#0f766e;fontColor=#ffffff;fontSize=13;fontStyle=1;arcSize=5;verticalAlign=middle;"
