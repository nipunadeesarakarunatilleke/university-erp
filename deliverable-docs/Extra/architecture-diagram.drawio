        <!-- Kafka header text -->
        <mxCell id="62" value="&lt;b&gt;⚡ Apache Kafka 3.7 — KRaft Mode (No Zookeeper)&lt;/b&gt;  ·  Internal Broker :9092  ·  Controller :9094  ·  auto.create.topics.enable = true"
          style="text;html=1;align=center;verticalAlign=middle;resizable=0;strokeColor=none;fillColor=none;fontSize=12;fontColor=#ffffff;"
