        </mxCell>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- LAYER 2: MICROSERVICES                         -->
        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="6" value="MICROSERVICES LAYER — 6 independently deployable services, each owning its own database"
          style="text;html=1;align=left;verticalAlign=middle;resizable=0;strokeColor=none;fillColor=none;fontSize=9;fontStyle=1;fontColor=#8892a4;"
          vertex="1" parent="1">
          <mxGeometry x="27" y="162" width="900" height="16" as="geometry" />
        </mxCell>

        <!-- AUTH SERVICE -->
        <mxCell id="10" value="Auth Service · :3007"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#ffffff;fontSize=13;fontStyle=1;arcSize=5;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="27" y="180" width="255" height="38" as="geometry" />
        </mxCell>
        <mxCell id="11" value="&lt;b&gt;Middleware&lt;/b&gt;&lt;br&gt;bcrypt (hash factor 12)&lt;br&gt;&lt;br&gt;&lt;b&gt;Routes&lt;/b&gt;&lt;br&gt;POST /auth/register&lt;br&gt;POST /auth/login&lt;br&gt;POST /auth/seed&lt;br&gt;&lt;br&gt;&lt;b&gt;Models&lt;/b&gt;&lt;br&gt;User.js&lt;br&gt;&lt;br&gt;&lt;b&gt;Roles&lt;/b&gt;&lt;br&gt;ADMIN · EXAM_DIVISION&lt;br&gt;HOD · LECTURER · STUDENT&lt;br&gt;&lt;br&gt;&lt;b&gt;Issues&lt;/b&gt;&lt;br&gt;JWT (24h expiry)"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#3b82f6;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=6;"
          vertex="1" parent="1">
          <mxGeometry x="27" y="218" width="255" height="258" as="geometry" />
        </mxCell>

        <!-- STUDENT SERVICE -->
        <mxCell id="12" value="Student Service · :3001"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#22c55e;strokeColor=#16a34a;fontColor=#ffffff;fontSize=13;fontStyle=1;arcSize=5;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="296" y="180" width="255" height="38" as="geometry" />
        </mxCell>
        <mxCell id="13" value="&lt;b&gt;Middleware&lt;/b&gt;&lt;br&gt;auth.js (JWT verify)&lt;br&gt;&lt;br&gt;&lt;b&gt;Routes&lt;/b&gt;&lt;br&gt;students.js&lt;br&gt;specializations.js&lt;br&gt;&lt;br&gt;&lt;b&gt;Key Endpoints&lt;/b&gt;&lt;br&gt;POST /students (+ bulk)&lt;br&gt;POST /:id/photo (multer)&lt;br&gt;POST /:id/year-registration&lt;br&gt;PATCH /spec/:id/assign&lt;br&gt;&lt;br&gt;&lt;b&gt;Models&lt;/b&gt;&lt;br&gt;Student.js&lt;br&gt;YearRegistration.js&lt;br&gt;SpecializationApp.js&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#7a5800&quot;&gt;&lt;b&gt;▶ Kafka: Publishes student.created&lt;/b&gt;&lt;/font&gt;"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#22c55e;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=6;"
          vertex="1" parent="1">
          <mxGeometry x="296" y="218" width="255" height="258" as="geometry" />
        </mxCell>

        <!-- EXAM SERVICE -->
        <mxCell id="14" value="Exam Service · :3003"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f97316;strokeColor=#c2410c;fontColor=#ffffff;fontSize=13;fontStyle=1;arcSize=5;verticalAlign=middle;"
