        <mxCell id="20" value="Notification Service · :3006"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ef4444;strokeColor=#b91c1c;fontColor=#ffffff;fontSize=13;fontStyle=1;arcSize=5;verticalAlign=middle;"
