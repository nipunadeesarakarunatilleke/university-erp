        <mxCell id="15" value="&lt;b&gt;Middleware&lt;/b&gt;&lt;br&gt;auth.js (JWT verify)&lt;br&gt;&lt;br&gt;&lt;b&gt;Routes&lt;/b&gt;&lt;br&gt;exams.js&lt;br&gt;&lt;br&gt;&lt;b&gt;Key Endpoints&lt;/b&gt;&lt;br&gt;POST /exams&lt;br&gt;PATCH /:id/schedule&lt;br&gt;POST /:id/entries&lt;br&gt;PATCH /:id/entries/:eid&lt;br&gt;&lt;br&gt;&lt;b&gt;Models&lt;/b&gt;&lt;br&gt;Exam.js&lt;br&gt;Entry.js&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#1a56db&quot;&gt;REST → Student Svc (validate)&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#7a5800&quot;&gt;&lt;b&gt;▶ Kafka: Publishes exam.registered&lt;/b&gt;&lt;/font&gt;"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f97316;fontSize=10;align=left;verticalAlign=top;spacingLeft=6;spacingTop=6;"
          vertex="1" parent="1">
