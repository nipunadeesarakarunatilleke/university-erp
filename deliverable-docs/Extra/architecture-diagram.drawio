        </mxCell>

        <mxCell id="5" value="&lt;b&gt;🌐  Browser SPA (jQuery + Bootstrap 5)&lt;/b&gt;  ·  nginx :8080  ·  All API requests proxied to microservices by URL path prefix"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a7d3e;strokeColor=#065c2d;fontColor=#ffffff;fontSize=13;arcSize=4;align=center;"
          vertex="1" parent="1">
