        <!-- ═══════════════════════════════════════════════ -->
        <mxCell id="60" value="⚡ ASYNCHRONOUS EVENT BUS — Kafka connects microservices to microservices, NOT to databases"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#c8d0dc;strokeWidth=1;fontSize=10;fontStyle=1;fontColor=#64748b;align=center;"
